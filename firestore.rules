rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['email', 'role', 'createdAt', 'updatedAt']) &&
               data.email is string && data.email.size() <= 256 &&
               data.role is string && (data.role == 'customer' || data.role == 'admin') &&
               data.createdAt is timestamp &&
               data.updatedAt is timestamp;
      }
      
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    isValidUser(incoming()) && 
                    incoming().role == 'customer' && // Cannot auto-assign admin
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      allow update: if isSignedIn() && request.auth.uid == userId &&
                    isValidUser(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt']) &&
                    incoming().role == existing().role &&
                    incoming().email == existing().email &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;
    }

    // Products (Public read, admin write)
    match /products/{productId} {
      function isAdmin() {
        return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders (User read/create, admin read/write)
    match /orders/{orderId} {
      function isAdmin() {
        return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
      function isValidOrder(data) {
        return data.keys().hasAll(['userId', 'items', 'totalAmount', 'status', 'createdAt']) &&
               data.userId == request.auth.uid &&
               data.items is list && data.items.size() <= 50 &&
               data.totalAmount is number &&
               data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
               data.createdAt is timestamp;
      }

      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin();
    }
  }
}
